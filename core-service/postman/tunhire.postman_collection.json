{
  "info": {
    "name": "Tunhire API",
    "description": "Companies and Applications endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081"
    }
  ],
  "item": [
    {
      "name": "Companies",
      "item": [
        {
          "name": "Create company",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme\",\n  \"slug\": \"acme\",\n  \"description\": \"Fintech company\",\n  \"logoUrl\": \"https://example.com/logo.png\",\n  \"website\": \"https://acme.tn\",\n  \"location\": \"Tunis\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/companies",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "companies"
              ]
            }
          }
        },
        {
          "name": "Get company by id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/companies/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "companies",
                "1"
              ]
            }
          }
        },
        {
          "name": "Get company by slug",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/companies/slug/acme",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "companies",
                "slug",
                "acme"
              ]
            }
          }
        },
        {
          "name": "Update company",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Updated\",\n  \"description\": \"Updated description\",\n  \"logoUrl\": \"https://example.com/logo2.png\",\n  \"website\": \"https://acme.tn\",\n  \"location\": \"Sfax\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/companies/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "companies",
                "1"
              ]
            }
          }
        },
        {
          "name": "Company jobs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/companies/1/jobs",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "companies",
                "1",
                "jobs"
              ]
            }
          }
        },
        {
          "name": "Company applications",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/companies/1/applications",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "companies",
                "1",
                "applications"
              ]
            }
          }
        },
        {
          "name": "Company dashboard",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/companies/1/dashboard",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "companies",
                "1",
                "dashboard"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "Create application",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jobId\": 10,\n  \"userId\": 20\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/applications",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "applications"
              ]
            }
          }
        },
        {
          "name": "Get application by id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/applications/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "applications",
                "1"
              ]
            }
          }
        },
        {
          "name": "List applications by jobId",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/applications?jobId=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "applications"
              ],
              "query": [
                {
                  "key": "jobId",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "List applications by userId",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/applications?userId=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "applications"
              ],
              "query": [
                {
                  "key": "userId",
                  "value": "20"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
